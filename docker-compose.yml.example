# neko-vision — llama.cpp連携画像自動タグ付け/キャプション生成マイクロサービス
#
# Usage:
#   cp docker-compose.yml.example docker-compose.yml
#   mkdir -p models
#   # Download GGUF models from Hugging Face (e.g. unsloth/gemma-4-E2B-it-GGUF):
#   #   gemma-4-E2B-it-Q4_K_M.gguf (本体, ~3.1 GB)
#   #   mmproj-gemma-4-E2B-it-BF16.gguf (ビジョン projector)
#   # ※ファイル名はリポジトリにより異なる場合あり。command 内のパスと一致させること。
#   docker compose up -d
#
# GPU を使う場合は llama イメージを :server-cuda に変更。
# NVIDIA GPU + nvidia-container-toolkit が必要。
#
# Connect from the main Nekonoverse server:
#   NEKO_VISION_URL=http://<this-machine>:8004/tag

services:
  llama:
    image: ghcr.io/ggml-org/llama.cpp:server
    # GPU を使う場合は :server-cuda に変更
    volumes:
      - ./models:/models:ro
    command: >
      -m /models/gemma-4-E2B-it-Q4_K_M.gguf
      --mmproj /models/mmproj-gemma-4-E2B-it-BF16.gguf
      --host 0.0.0.0
      --port 8080
      -c 16384
      -np 2
    networks:
      - internal
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8080/health"]
      interval: 30s
      timeout: 5s
      retries: 3

  neko-vision:
    build: .
    restart: unless-stopped
    ports:
      - "8004:8004"
    environment:
      LLAMA_URL: http://llama:8080
    depends_on:
      llama:
        condition: service_healthy
    networks:
      - internal
      - default

networks:
  internal:
    internal: true
